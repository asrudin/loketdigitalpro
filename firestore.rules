rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Global Safety Net - default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // 2. User State Authorization - scoped strictly to the authenticated user ID or public with device ID
    match /userStates/{userId} {
      allow read, write: if true;
    }
  }
}
